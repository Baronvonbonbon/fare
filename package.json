{
  "name": "fare-protocol",
  "version": "0.1.0",
  "description": "FARE — P2P delivery network on Polkadot Hub. Customers, drivers, and venues coordinate deliveries through on-chain reverse auctions and dual-signed GPS attestations, with no intermediary.",
  "license": "GPL-3.0-or-later",
  "scripts": {
    "build": "hardhat compile",
    "test": "hardhat test",
    "node": "hardhat node",
    "deploy:local": "hardhat run scripts/deploy.ts --network localhost",
    "deploy:paseo": "hardhat run scripts/deploy.ts --network polkadotTestnet",
    "seed:local": "hardhat run scripts/seed.ts --network localhost",
    "seed:paseo": "hardhat run scripts/seed-paseo.ts --network polkadotTestnet",
    "zk:setup": "node scripts/setup-zk.mjs",
    "probe:coverage": "node scripts/shield/coverage-swap.mjs",
    "size": "hardhat size-contracts"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "circomlib": "^2.0.5",
    "circomlibjs": "^0.1.7",
    "dotenv": "^16.4.5",
    "hardhat": "^2.22.0",
    "poseidon-lite": "^0.3.0",
    "snarkjs": "^0.7.5",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.2",
    "@polkadot/api": "^16.5.6"
  }
}
