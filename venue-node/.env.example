# FARE venue relay config — copy to venue-node/.env (gitignored) and run:
#   npm install && npm run relay

# Funded venue account that pays gas (NEVER commit the real key).
RELAY_PRIVATE_KEY=
RELAY_RPC_URL=https://eth-rpc-testnet.polkadot.io/
RELAY_PORT=8788

# Gas sponsorship (/fund): top up burners below FUND_MIN up to FUND_AMOUNT.
FUND_AMOUNT_PAS=5
FUND_MIN_PAS=2

# Path (relative to relay.mjs) to the deployed address book — for the settlement address.
ADDRESS_BOOK=../deployed-addresses.json

# EIP-2771 forwarder for gasless user actions (F8). Defaults to `forwarder` in the
# address book; set to override. If unset/absent, POST /forward returns 503.
FORWARDER_ADDRESS=
# FareVault for gasless withdraw (F8). Defaults to `vault` in the address book;
# set to override. If unset/absent, POST /withdraw returns 503.
VAULT_ADDRESS=

# CORS: comma-separated origins, or * for open (behind a rate-limited proxy).
ALLOWED_ORIGINS=*
RATE_MAX=20

# ── Profitability guard (F6/F8 economics) ────────────────────────────────────
# The relay only sponsors what pays off. Reward-bearing actions (dropoff
# settlement → F6 rebate; withdrawFor → F8 fee) are relayed only if the reward
# covers the fare's cumulative relayed gas × margin; no-reward actions (fund /
# bids / pickup / cancels / rate) are sponsored under a rolling gas budget.
# NOTE: on testnet, demo fares are tiny (rebate << gas), so the guard will
# usually DECLINE settlement → the app prompts "pay your own gas?". Set
# RELAY_PROFIT_GUARD=off for a fully-gasless demo, or raise the on-chain
# relayRebateBps / feeBps so the rebate actually covers gas.
RELAY_PROFIT_GUARD=on
RELAY_MIN_MARGIN=1.25            # reward must be ≥ cost × this
RELAY_GAS_BUDGET_PAS=50         # max no-reward subsidy per window
RELAY_BUDGET_WINDOW_MS=86400000 # 1 day
# Override the orders address for reward reads (else read from the address book):
ORDERS_ADDRESS=

# ── Region push service (push.mjs / B4 P2) ───────────────────────────────────
# Background Web Push, notified BY REGION (never per-order). Generate a keypair:
#   npx web-push generate-vapid-keys
# Put the PUBLIC key here AND in the web build as VITE_VAPID_PUBLIC_KEY; keep the
# PRIVATE key secret (this file only, gitignored).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@fare.example
PUSH_PORT=8791
PUSH_RPC_URL=https://eth-rpc-testnet.polkadot.io/
PUSH_START_BLOCK=0
PUSH_POLL_MS=15000

# ── Replication agent (agent.mjs / F3) ───────────────────────────────────────
# Chain to read venue events from (defaults to RELAY_RPC_URL if unset).
AGENT_RPC_URL=https://eth-rpc-testnet.polkadot.io/
# Local Kubo RPC API. In docker-compose this is overridden to http://kubo:5001.
KUBO_API_URL=http://127.0.0.1:5001
AGENT_PORT=8789

# This venue's home coordinate, in MICRODEGREES (lat/lon × 1e6). REQUIRED — it
# defines the region pinned generously. e.g. San Francisco = 37.7749,-122.4194:
HOME_LAT=37774900
HOME_LON=-122419400
# HOSTED SUPER-NODE (F7): to serve MANY venues from one box, set HOME_COORDS to a
# semicolon-separated list of "lat,lon" centers (microdegrees) instead — the
# agent pins the union of all their regions. Wins over HOME_LAT/HOME_LON. e.g.:
# HOME_COORDS=37774900,-122419400;40712800,-74006000
HOME_COORDS=
# Pin the home region ± this radius (km); plus a small global sample.
REGION_RADIUS_KM=60
GLOBAL_SAMPLE=50
# Backfill start block (0 = from genesis); poll cadence for new logs.
START_BLOCK=0
POLL_MS=15000

# Public service endpoints echoed into the region manifest for F4/F8 clients
# (leave blank if not publicly reachable). Point these at the Caddy proxy:
PUBLIC_GATEWAY=
PUBLIC_RPC=
# This region's gasless relay endpoint (F8). Clients discover it from the
# manifest and prefer it over the build-time VITE_RELAY_URL (DATUM relayUrl pattern).
PUBLIC_RELAY=

# ── Data-availability scorer (scorer.mjs / F5) ───────────────────────────────
# Challenges peer nodes (do they actually serve the region's menus?) + blends in
# client availability reports → a per-node DA score + leaderboard. Run this on a
# monitor, not necessarily every venue.
# Comma-separated Caddy base URLs of the nodes to monitor (each exposes /agent + /ipfs):
SCORER_NODES=
SCORER_PORT=8790
# Trusted reference gateway used to fetch canonical (CID-verified) content to
# compare a node's served bytes against.
REFERENCE_GATEWAY=https://ipfs.io/ipfs/
SCORER_SAMPLE=5             # CIDs challenged per node per round
SCORER_LATENCY_MS=8000      # per-challenge latency bound
SCORER_ROUND_MS=300000      # 5 min between challenge rounds
SCORER_CHALLENGE_WEIGHT=0.7 # challenge vs. client-report weight in the blend
SCORER_REPORT_HALFLIFE_MS=3600000 # client-report decay half-life (1h)

# ── Shielded burner funding (C4 / POST /shield-withdraw) ─────────────────────
# The Kusama Shield pool to relay proxy_withdraw against (native PAS, v7).
SHIELD_POOL=0x7d5a496bD61b631025A828d9049f6A68e007e0dC
# Relayer fee for a shielded withdrawal, in PAS. 0 = sponsor mode (recipient is
# the burner, relay eats gas, trustless). > 0 = fee mode (recipient is the relay,
# which forwards withdrawnValue−fee to the burner and keeps the fee to cover its
# ~0.77 PAS proxy_withdraw gas). See README "Shielded burner funding".
SHIELD_FEE_PAS=0

# ── Sponsored onboarding (POST /onboard, Route A) ────────────────────────────
# Seed a fresh driver/venue wallet with existential-deposit + register gas so a
# new participant can register and immediately begin earning. OFF by default (a
# loss-leader / gas-drain surface). Budget-gated + one-seed-per-address; venues
# are region-gated when ONBOARD_LAT/LON are set. See docs/RELAY-SPONSORSHIP.md.
ONBOARD_ENABLED=off
ONBOARD_SEED_PAS=2
# Optional venue region gate (µdeg); only sponsor venues within RADIUS of here.
ONBOARD_LAT=
ONBOARD_LON=
ONBOARD_RADIUS_KM=60

# ── RPC resilience (F4) ──────────────────────────────────────────────────────
# AGENT_RPC_URL / RELAY_RPC_URL may be a COMMA-SEPARATED failover list. If set,
# PINE_RPC (a local pine/smoldot light client) is used first (trust-minimized),
# with the list as failover. Run one via `docker compose --profile pine up`.
PINE_RPC=
RPC_STALL_MS=3000
CHAIN_ID=420420417

# ── Relay treasury: fee coverage + auto fee-recovery swaps (docs/RELAY-TREASURY.md)
# A gasless TOKEN order pays the relay its F6 rebate in the ORDER TOKEN (USDC) but
# gas is spent in NATIVE (PAS). RELAY_TOKEN_PRICE (native per whole token) lets the
# profitability guard value that rebate in native so it can decide coverage. Unset
# ⇒ the relay DECLINES token settlements (it can't prove the fee covers gas).
RELAY_TOKEN_PRICE=
# Auto fee-recovery: when native gas < floor, swap accrued token fees → native via
# Hydration (Paraspell XCM Router) submitted through the Asset Hub XCM precompile.
# Live-swap needs a real Asset-Hub-asset fee token (MockUSDC is EVM-only) — see doc.
SWAP_ENABLED=off
HYDRATION_RPC=wss://paseo-rpc.play.hydration.cloud
GAS_FLOOR_PAS=50
GAS_TARGET_PAS=200
GAS_RESERVE_PAS=5
MIN_SWAP_TOKEN_UNITS=0
SWAP_POLL_MS=300000
