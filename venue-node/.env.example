# FARE venue relay config — copy to venue-node/.env (gitignored) and run:
#   npm install && npm run relay

# Funded venue account that pays gas (NEVER commit the real key).
RELAY_PRIVATE_KEY=
RELAY_RPC_URL=https://eth-rpc-testnet.polkadot.io/
RELAY_PORT=8788

# Gas sponsorship (/fund): top up burners below FUND_MIN up to FUND_AMOUNT.
FUND_AMOUNT_PAS=5
FUND_MIN_PAS=2

# Path (relative to relay.mjs) to the deployed address book — for the settlement address.
ADDRESS_BOOK=../deployed-addresses.json

# CORS: comma-separated origins, or * for open (behind a rate-limited proxy).
ALLOWED_ORIGINS=*
RATE_MAX=20

# ── Replication agent (agent.mjs / F3) ───────────────────────────────────────
# Chain to read venue events from (defaults to RELAY_RPC_URL if unset).
AGENT_RPC_URL=https://eth-rpc-testnet.polkadot.io/
# Local Kubo RPC API. In docker-compose this is overridden to http://kubo:5001.
KUBO_API_URL=http://127.0.0.1:5001
AGENT_PORT=8789

# This venue's home coordinate, in MICRODEGREES (lat/lon × 1e6). REQUIRED — it
# defines the region pinned generously. e.g. San Francisco = 37.7749,-122.4194:
HOME_LAT=37774900
HOME_LON=-122419400
# HOSTED SUPER-NODE (F7): to serve MANY venues from one box, set HOME_COORDS to a
# semicolon-separated list of "lat,lon" centers (microdegrees) instead — the
# agent pins the union of all their regions. Wins over HOME_LAT/HOME_LON. e.g.:
# HOME_COORDS=37774900,-122419400;40712800,-74006000
HOME_COORDS=
# Pin the home region ± this radius (km); plus a small global sample.
REGION_RADIUS_KM=60
GLOBAL_SAMPLE=50
# Backfill start block (0 = from genesis); poll cadence for new logs.
START_BLOCK=0
POLL_MS=15000

# Public service endpoints echoed into the region manifest for F4 clients
# (leave blank if not publicly reachable). Point these at the Caddy proxy:
PUBLIC_GATEWAY=
PUBLIC_RPC=

# ── Data-availability scorer (scorer.mjs / F5) ───────────────────────────────
# Challenges peer nodes (do they actually serve the region's menus?) + blends in
# client availability reports → a per-node DA score + leaderboard. Run this on a
# monitor, not necessarily every venue.
# Comma-separated Caddy base URLs of the nodes to monitor (each exposes /agent + /ipfs):
SCORER_NODES=
SCORER_PORT=8790
# Trusted reference gateway used to fetch canonical (CID-verified) content to
# compare a node's served bytes against.
REFERENCE_GATEWAY=https://ipfs.io/ipfs/
SCORER_SAMPLE=5             # CIDs challenged per node per round
SCORER_LATENCY_MS=8000      # per-challenge latency bound
SCORER_ROUND_MS=300000      # 5 min between challenge rounds
SCORER_CHALLENGE_WEIGHT=0.7 # challenge vs. client-report weight in the blend
SCORER_REPORT_HALFLIFE_MS=3600000 # client-report decay half-life (1h)
